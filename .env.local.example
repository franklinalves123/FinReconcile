# =============================================================================
# FinReconcile — Variáveis de Ambiente
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.local.example .env.local
#   2. Preencha os valores abaixo no .env.local (nunca commite esse arquivo)
#   3. Rode: npm run dev
# =============================================================================

# --- Supabase (BaaS / Banco de Dados / Auth) ----------------------------------
# Encontre em: https://app.supabase.com → Projeto → Settings → API
# A anon key é pública por design — o RLS do Supabase protege os dados.
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica-aqui

# --- Gemini AI ----------------------------------------------------------------
# Obtenha em: https://aistudio.google.com/app/apikey
#
# ATENÇÃO — Risco residual (MVP):
#   Esta chave é injetada no bundle compilado via `npm run build`.
#   Qualquer pessoa pode extraí-la inspecionando o JS do site em produção.
#
# Para segurança total (recomendado antes de compartilhar a URL publicamente):
#   1. Implante a Supabase Edge Function em supabase/functions/gemini-proxy/
#   2. Defina VITE_USE_EDGE_FUNCTION=true abaixo
#   3. Remova VITE_GEMINI_API_KEY do .env.local (a key fica só no Supabase)
#
VITE_GEMINI_API_KEY=sua-gemini-api-key-aqui

# --- Modo Edge Function -------------------------------------------------------
# DESENVOLVIMENTO LOCAL:  VITE_USE_EDGE_FUNCTION=false  (Layer 1 — chave no bundle, OK em dev)
# PRODUÇÃO (Vercel):      VITE_USE_EDGE_FUNCTION=true   (Layer 2 — chave NUNCA no bundle)
#
# Para ativar Layer 2 em produção:
#   1. Deploy da Edge Function: supabase functions deploy gemini-proxy
#   2. Definir VITE_USE_EDGE_FUNCTION=true no Vercel Dashboard > Environment Variables
#   3. Verificar após build: grep -r "AIzaSy" dist/ (deve retornar vazio)
#   4. Com Layer 2 ativo, VITE_GEMINI_API_KEY não precisa estar no ambiente de produção
VITE_USE_EDGE_FUNCTION=false

# --- OpenAI (Fallback IA — Nível 2) ------------------------------------------
# Usado como fallback automático quando o Gemini retorna erro 429 (quota).
# Obtenha em: https://platform.openai.com/api-keys
# Modelo: gpt-4o-mini (categorização de transações)
#
# ATENÇÃO — segurança (mesmo risco que VITE_GEMINI_API_KEY):
#   A chave fica no bundle compilado. Use apenas em desenvolvimento ou
#   mova a chamada para uma Edge Function em produção.
#
VITE_OPENAI_API_KEY=sua-openai-api-key-aqui

# --- Anthropic / Claude (Fallback IA — Nível 3) -------------------------------
# Usado como fallback automático quando Gemini e OpenAI falham.
# Suporta extração de PDF nativa (document blocks) — melhor fallback para PDFs.
# Obtenha em: https://console.anthropic.com/settings/keys
# Modelo: claude-haiku-4-5-20251001 (extração de PDF + categorização)
#
# ATENÇÃO — segurança (mesmo risco que VITE_GEMINI_API_KEY):
#   A chave fica no bundle compilado. Use apenas em desenvolvimento ou
#   mova a chamada para uma Edge Function em produção.
#
VITE_ANTHROPIC_API_KEY=sua-anthropic-api-key-aqui

# --- Administração ------------------------------------------------------------
# Email do usuário com permissão de master/admin no app
VITE_MASTER_EMAIL=seu-email@gmail.com
